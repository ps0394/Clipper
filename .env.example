# Phase 5 LLM ground-truth validation — environment template.
#
# Copy to .env and fill in values. .env is gitignored; do not commit.
#
# The Foundry resource hosts all three models; the inference endpoint
# is the same URL with only the deployment name varying per call.

# Azure AI Foundry project endpoint (the Overview page field labeled
# "Microsoft Foundry project endpoint"). The inference SDK expects the
# models route, so either form below works:
#   https://<resource>.services.ai.azure.com/api/projects/<project>
#   https://<resource>.services.ai.azure.com/models
PHASE5_FOUNDRY_ENDPOINT=https://ai-model-for-clipper.services.ai.azure.com/api/projects/Clipper

# API key from the Foundry resource Overview page (the masked field).
# Required unless you switch to Entra ID auth.
PHASE5_FOUNDRY_API_KEY=

# Deployment names. Must match exactly what you named the deployments
# on the Models + endpoints page.
PHASE5_GENERATOR_DEPLOYMENT=Mistral-Large-3
PHASE5_SCORER_PRIMARY_DEPLOYMENT=gpt-4.1
PHASE5_SCORER_SECONDARY_DEPLOYMENT=Llama-3.3-70B-Instruct
